# Environment variables — copy this file to .env and fill in your values
# .env is gitignored and must never be committed

# Required: The Odds API key for live sportsbook lines
# Get one at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Optional: Minimum edge threshold for value bet detection (default: 0.05 = 5%)
VALUE_BET_THRESHOLD=0.05
