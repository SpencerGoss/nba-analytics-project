{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Daily Update",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/update.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Backfill",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backfill.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Serve Dashboard",
            "type": "debugpy",
            "request": "launch",
            "module": "http.server",
            "args": ["8080", "--directory", "dashboard"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Sync to SQL Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/sync_to_sqlserver.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Optimize Dashboard",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/optimize_dashboard.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Single Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
